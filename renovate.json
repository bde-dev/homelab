{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "kubernetes": {
    "fileMatch": [
      "\\.yaml$"
    ]
  },
  "flux": {
    "fileMatch": [
      "\\.yaml$"
    ]
  },
  "branchConcurrentLimit": 0,
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "packageRules": [
    {
      "matchPaths": [
        "clusters/**"
      ],
      "addLabels": [
        "flux"
      ]
    },
    {
      "matchPaths": [
        "infrastructure/**"
      ],
      "addLabels": [
        "infrastructure"
      ]
    },
    {
      "matchPaths": [
        "monitoring/**"
      ],
      "addLabels": [
        "monitoring"
      ]
    },
    {
      "matchPaths": [
        "apps/**"
      ],
      "addLabels": [
        "apps"
      ]
    },
    {
      "matchPaths": [
        "mise.toml"
      ],
      "addLabels": [
        "mise"
      ]
    },
    {
      "description": "Disable Renovate under flux-system",
      "matchPaths": [
        "clusters/olympus/flux-system/**"
      ],
      "enabled": false
    },
    {
      "matchPackageNames": [
        "cloudflare/cloudflared"
      ],
      "addLabels": [
        "infrastructure"
      ],
      "groupName": "cloudflared"
    },
    {
      "description": "Link commafeed to GitHub. extractVersion requires -postgresql suffix (filtering out -h2/-mysql/-mariadb variants) and strips it for changelog matching against GitHub release tags.",
      "matchPackageNames": [
        "athou/commafeed"
      ],
      "sourceUrl": "https://github.com/Athou/commafeed",
      "extractVersion": "^(?<version>\\d+\\.\\d+\\.\\d+)-postgresql$"
    },
    {
      "description": "Link Synology CSI driver to GitHub source for release notes.",
      "matchPackageNames": [
        "synology/synology-csi"
      ],
      "sourceUrl": "https://github.com/SynologyOpenSource/synology-csi"
    },
    {
      "description": "Link CSI provisioner sidecar to GitHub source for release notes.",
      "matchPackageNames": [
        "registry.k8s.io/sig-storage/csi-provisioner"
      ],
      "sourceUrl": "https://github.com/kubernetes-csi/external-provisioner"
    },
    {
      "description": "Link CSI attacher sidecar to GitHub source for release notes.",
      "matchPackageNames": [
        "registry.k8s.io/sig-storage/csi-attacher"
      ],
      "sourceUrl": "https://github.com/kubernetes-csi/external-attacher"
    },
    {
      "description": "Link CSI resizer sidecar to GitHub source for release notes.",
      "matchPackageNames": [
        "registry.k8s.io/sig-storage/csi-resizer"
      ],
      "sourceUrl": "https://github.com/kubernetes-csi/external-resizer"
    },
    {
      "description": "Link CSI node-driver-registrar sidecar to GitHub source for release notes.",
      "matchPackageNames": [
        "registry.k8s.io/sig-storage/csi-node-driver-registrar"
      ],
      "sourceUrl": "https://github.com/kubernetes-csi/node-driver-registrar"
    }
  ]
}
